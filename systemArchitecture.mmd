flowchart TB
    subgraph UI["User Interface Layer"]
        Menu["Console Menu\n(menu-driven interface)"]
    end

    subgraph Core["Core Controller"]
        PM["ParkingManager\n(central system brain)"]
    end

    subgraph Modules["System Modules (SRS Tasks)"]
        T1["Task 1: Slot Configuration\nadd & manage parking slots"]
        T2["Task 2: Vehicle Entry\nregister & allocate slot"]
        T3["Task 3: Fee Calculation\ncompute bill at exit"]
        T4["Task 4: Vehicle Exit\nrelease slot & save record"]
        Reports["Operational Reports\nslots, parked vehicles,\nhistory, daily revenue"]
    end

    subgraph Data["In-Memory Data Layer"]
        Slots["vector&lt;ParkingSlot&gt;\nstores all slots"]
        Active["unordered_map&lt;string, Vehicle&gt;\nactive vehicles by plate"]
        History["vector&lt;ParkingTransaction&gt;\ncompleted parking records"]
    end

    subgraph Model["Domain Classes"]
        PS["ParkingSlot\nID, type, zone, status"]
        V["Vehicle\nplate, type, entry time, slot"]
        PT["ParkingTransaction\nentry/exit, hours, fee"]
        TM["TariffManager\nactive hourly rates"]
    end

    subgraph OOP["OOP Design"]
        Display["Displayable (abstract)\n↳ ParkingSlot, ParkingTransaction"]
        Tariff["TariffPolicy (abstract)\n↳ Motorcycle, Car, Truck tariffs"]
    end

    Menu -->|"user choice"| PM

    PM --> T1
    PM --> T2
    PM --> T3
    PM --> T4
    PM --> Reports

    T1 --> Slots
    T2 --> Slots
    T2 --> Active
    T3 --> TM
    T4 --> Slots
    T4 --> Active
    T4 --> History
    T4 --> TM
    Reports --> Slots
    Reports --> Active
    Reports --> History

    Slots --- PS
    Active --- V
    History --- PT
    TM --- Tariff

    PS -.-> Display
    PT -.-> Display
